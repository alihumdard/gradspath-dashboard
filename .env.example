APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Main application database.
# PHPUnit is configured separately in phpunit.xml to use grads_path_test.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=grads_path
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

HORIZON_NAME="${APP_NAME}"
HORIZON_USE=default
HORIZON_PATH=horizon
HORIZON_PREFIX=
HORIZON_FAST_TERMINATION=false
HORIZON_MEMORY_LIMIT=64
HORIZON_SUPERVISOR_MAX_PROCESSES=1
HORIZON_SUPERVISOR_MEMORY=128
HORIZON_SUPERVISOR_TRIES=1
HORIZON_SUPERVISOR_TIMEOUT=60
HORIZON_LOCAL_MAX_PROCESSES=3
HORIZON_PRODUCTION_MAX_PROCESSES=10
HORIZON_PRODUCTION_BALANCE_MAX_SHIFT=1
HORIZON_PRODUCTION_BALANCE_COOLDOWN=3

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=123456
REVERB_APP_KEY=localreverbkey
REVERB_APP_SECRET=localreverbsecret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE=https://api.stripe.com/v1
STRIPE_CONNECT_COUNTRY=US
STRIPE_BOOKING_SUCCESS_URL=
STRIPE_BOOKING_CANCEL_URL=
MENTOR_PAYOUT_PERCENT_DEFAULT=70
MENTOR_PAYOUT_RETRY_LIMIT=5

ZOOM_ENABLED=false
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
ZOOM_AUTHORIZE_URL=https://zoom.us/oauth/authorize
ZOOM_TOKEN_URL=https://zoom.us/oauth/token
ZOOM_API_BASE=https://api.zoom.us/v2
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_ATTENDANCE_NO_SHOW_GRACE_MINUTES=15
ZOOM_ATTENDANCE_FEEDBACK_FALLBACK_GRACE_MINUTES=60
ZOOM_ATTENDANCE_MINIMUM_OVERLAP_MINUTES=5

VITE_APP_NAME="${APP_NAME}"
